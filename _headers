# Cloudflare Pages _headers — caching + basic security
# Rules are matched top-to-bottom; later matches add/override headers per path.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# --- Security headers for everything ---
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# --- Long cache for versioned/static library modules ---
# /lib/* is treated as immutable; bust by changing the path/filename when you ship.
/lib/*
  Cache-Control: public, max-age=31536000, immutable

# Other static assets (fonts, images, css, bundled js, etc.)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# --- Never cache runtime config (git-ignored, environment-specific) ---
/config.js
  Cache-Control: no-cache, no-store, must-revalidate

# --- Never cache HTML so deploys go live immediately ---
/
  Cache-Control: no-cache, no-store, must-revalidate

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
